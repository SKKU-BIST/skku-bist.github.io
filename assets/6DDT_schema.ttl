@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sddt:  <https://skku-bist.github.io/assets/6DDT_schema.ttl#> .
@prefix brick: <https://brickschema.org/schema/Brick#> .
@prefix vb:    <https://skku-bist.github.io/method#> .

# =============================================================================
# ONTOLOGY HEADER
# =============================================================================

sddt:SixDDT a owl:Ontology ;
    rdfs:label "6D Digital Twin Ontology (Schema Skeleton)" ;
    rdfs:comment "Schema-only skeleton for 6DDT: classes, subclasses, relationships, and properties. Aligns with Brick and VB at schema level. Service is not a predefined class but an emergent runtime instance recorded through sddt:hasServiceInvocationID and related properties attached to the executing Tool." .

# =============================================================================
# CLASSES — TOP-LEVEL (6 classes)
# =============================================================================

sddt:Entity a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "Top-level concept for anything represented in a 6D digital twin." .

sddt:DTData a owl:Class ;
    rdfs:label "DT Data" ;
    rdfs:subClassOf sddt:Entity ;
    rdfs:comment "Structured or unstructured records of measured, observed, or derived values describing system state over time." .

sddt:PhysicalEntity a owl:Class ;
    rdfs:label "Physical Entity" ;
    rdfs:subClassOf sddt:Entity ;
    rdfs:comment "Real-world manufactured product, system, or space that exists physically and has measurable characteristics across its lifecycle." .

sddt:VirtualModel a owl:Class ;
    rdfs:label "Virtual Model" ;
    rdfs:subClassOf sddt:Entity ;
    rdfs:comment "Formal representation used to approximate, simulate, estimate, or calibrate behaviour or state under defined assumptions." .

sddt:Tool a owl:Class ;
    rdfs:label "Tool" ;
    rdfs:subClassOf sddt:Entity ;
    rdfs:comment "Software capability that executes tasks and produces outputs. Tool is a Service executor in the 6DDT framework." .

sddt:AIAgent a owl:Class ;
    rdfs:label "AI Agent" ;
    rdfs:subClassOf sddt:Entity ;
    rdfs:comment "Autonomous system that perceives, reasons, and acts to achieve objectives by invoking tools. AI Agent is a Service executor in the 6DDT framework." .

# =============================================================================
# CLASSES — SUBCLASSES OF DTData (6 subclasses)
# =============================================================================

sddt:SensorData a owl:Class ;
    rdfs:label "Sensor Data" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData that originates from physical sensing points." .

sddt:ToolData a owl:Class ;
    rdfs:label "Tool Data" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData produced or used by a tool execution." .

sddt:OMServiceLog a owl:Class ;
    rdfs:label "O&M Service Log" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData capturing O&M service execution context, actions, and outcomes." .

sddt:VirtualModelData a owl:Class ;
    rdfs:label "Virtual Model Data" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData generated by a VirtualModel such as predictions, estimates, or residuals." .

sddt:OMAgentAnswer a owl:Class ;
    rdfs:label "O&M Agent Answer" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData representing the agent final answer or service-related statement produced during O&M." .

sddt:ModelParameter a owl:Class ;
    rdfs:label "Model Parameter" ;
    rdfs:subClassOf sddt:DTData ;
    rdfs:comment "DTData storing parameter values associated with a specific model or component." .

# =============================================================================
# CLASSES — SUBCLASSES OF PhysicalEntity (4 subclasses)
# =============================================================================

sddt:Location a owl:Class ;
    rdfs:label "Location" ;
    rdfs:subClassOf sddt:PhysicalEntity ;
    rdfs:comment "A physical location or space container for assets such as a building, floor, or room." .

sddt:Equipment a owl:Class ;
    rdfs:label "Equipment" ;
    rdfs:subClassOf sddt:PhysicalEntity ;
    rdfs:comment "A physical equipment unit such as an AHU, VAV, fan, or coil." .

sddt:Point a owl:Class ;
    rdfs:label "Point" ;
    rdfs:subClassOf sddt:PhysicalEntity ;
    rdfs:comment "A physical sensing or actuation point including sensor, command, and setpoint points." .

sddt:ControlLoop a owl:Class ;
    rdfs:label "Control Loop" ;
    rdfs:subClassOf sddt:PhysicalEntity ;
    rdfs:comment "A control loop that links sensors, control variables, setpoints, and actuators." .

# =============================================================================
# CLASSES — SUBCLASSES OF VirtualModel (4 subclasses)
# =============================================================================

sddt:PhysicalModel a owl:Class ;
    rdfs:label "Physical Model" ;
    rdfs:subClassOf sddt:VirtualModel ;
    rdfs:comment "VirtualModel defined primarily by governing physical equations representing first-principles system behaviour." .

sddt:BehaviorModel a owl:Class ;
    rdfs:label "Behavior Model" ;
    rdfs:subClassOf sddt:VirtualModel ;
    rdfs:comment "VirtualModel capturing expert-defined control logic and system behavioural patterns." .

sddt:RuleModel a owl:Class ;
    rdfs:label "Rule Model" ;
    rdfs:subClassOf sddt:VirtualModel ;
    rdfs:comment "VirtualModel encoded as threshold-based diagnostic or control rules, such as those used in fault detection and diagnosis." .

sddt:GeometricModel a owl:Class ;
    rdfs:label "Geometric Model" ;
    rdfs:subClassOf sddt:VirtualModel ;
    rdfs:comment "VirtualModel describing spatial geometry, coordinates, and dimensional properties of physical locations." .

# =============================================================================
# CLASSES — SUBCLASSES OF Tool (4 subclasses, plus User Interface under Interaction Tool)
# =============================================================================

sddt:ModelingTool a owl:Class ;
    rdfs:label "Modeling Tool" ;
    rdfs:subClassOf sddt:Tool ;
    rdfs:comment "A tool used to construct, structure, or update model-based representations." .

sddt:SimulationTool a owl:Class ;
    rdfs:label "Simulation Tool" ;
    rdfs:subClassOf sddt:Tool ;
    rdfs:comment "A tool that executes computational or diagnostic procedures, such as fault detection and diagnosis." .

sddt:VisualizationTool a owl:Class ;
    rdfs:label "Visualization Tool" ;
    rdfs:subClassOf sddt:Tool ;
    rdfs:comment "A tool that presents service outputs, model states, or diagnostic results." .

sddt:InteractionTool a owl:Class ;
    rdfs:label "Interaction Tool" ;
    rdfs:subClassOf sddt:Tool ;
    rdfs:comment "A tool that supports human or agent interaction with the DT environment." .

sddt:UserInterface a owl:Class ;
    rdfs:label "User Interface" ;
    rdfs:subClassOf sddt:InteractionTool ;
    rdfs:comment "An interaction tool that supports service invocation, monitoring, and user-driven interaction, such as a dashboard or web UI." .

# =============================================================================
# OBJECT PROPERTIES — Core relationship pairs (Section 2.2 / Table 2)
# =============================================================================

sddt:hasInput a owl:ObjectProperty ;
    rdfs:label "has input" ;
    rdfs:domain sddt:Entity ;
    rdfs:range sddt:Entity ;
    rdfs:comment "Entity consumes another entity as an input for service execution or reasoning." .

sddt:isInputOf a owl:ObjectProperty ;
    rdfs:label "is input of" ;
    owl:inverseOf sddt:hasInput ;
    rdfs:domain sddt:Entity ;
    rdfs:range sddt:Entity ;
    rdfs:comment "Inverse of hasInput." .

sddt:generates a owl:ObjectProperty ;
    rdfs:label "generates" ;
    rdfs:domain sddt:Entity ;
    rdfs:range sddt:DTData ;
    rdfs:comment "Entity produces DTData as output." .

sddt:isGeneratedBy a owl:ObjectProperty ;
    rdfs:label "is generated by" ;
    owl:inverseOf sddt:generates ;
    rdfs:domain sddt:DTData ;
    rdfs:range sddt:Entity ;
    rdfs:comment "Inverse of generates." .

sddt:hasPart a owl:ObjectProperty ;
    rdfs:label "has part" ;
    rdfs:domain sddt:Entity ;
    rdfs:range sddt:Entity ;
    rdfs:comment "Whole-part compositional relationship between entities." .

sddt:isPartOf a owl:ObjectProperty ;
    rdfs:label "is part of" ;
    owl:inverseOf sddt:hasPart ;
    rdfs:domain sddt:Entity ;
    rdfs:range sddt:Entity ;
    rdfs:comment "Inverse of hasPart." .

# =============================================================================
# OBJECT PROPERTIES — Physical-Virtual linkage (with inverses)
# =============================================================================

sddt:hasVirtualData a owl:ObjectProperty ;
    rdfs:label "has virtual data" ;
    rdfs:domain sddt:PhysicalEntity ;
    rdfs:range sddt:DTData ;
    rdfs:comment "PhysicalEntity is associated with DTData representing its measured or estimated state." .

sddt:isVirtualDataOf a owl:ObjectProperty ;
    rdfs:label "is virtual data of" ;
    owl:inverseOf sddt:hasVirtualData ;
    rdfs:domain sddt:DTData ;
    rdfs:range sddt:PhysicalEntity ;
    rdfs:comment "Inverse of hasVirtualData." .

sddt:hasVirtualModel a owl:ObjectProperty ;
    rdfs:label "has virtual model" ;
    rdfs:domain sddt:PhysicalEntity ;
    rdfs:range sddt:VirtualModel ;
    rdfs:comment "PhysicalEntity is associated with a VirtualModel representing it." .

sddt:isVirtualModelOf a owl:ObjectProperty ;
    rdfs:label "is virtual model of" ;
    owl:inverseOf sddt:hasVirtualModel ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range sddt:PhysicalEntity ;
    rdfs:comment "Inverse of hasVirtualModel." .

sddt:isLinkedWith a owl:ObjectProperty ;
    rdfs:label "is linked with" ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range sddt:VirtualModel ;
    rdfs:comment "Links virtual models that are coupled or mutually dependent." .

# =============================================================================
# OBJECT PROPERTIES — Service traceability
# =============================================================================

sddt:invokesService a owl:ObjectProperty ;
    rdfs:label "invokes service" ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range sddt:Tool ;
    rdfs:comment "AIAgent invokes a Tool to execute a service, with the invocation context recorded via sddt:hasServiceInvocationID and related datatype properties on the Tool." .

sddt:isInvokedBy a owl:ObjectProperty ;
    rdfs:label "is invoked by" ;
    owl:inverseOf sddt:invokesService ;
    rdfs:domain sddt:Tool ;
    rdfs:range sddt:AIAgent ;
    rdfs:comment "Inverse of invokesService. Links the executing Tool to the AIAgent that invoked it." .

sddt:hasServiceOutput a owl:ObjectProperty ;
    rdfs:label "has service output" ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range sddt:DTData ;
    rdfs:comment "AI Agent produced service output recorded as DTData." .

# =============================================================================
# OBJECT PROPERTIES — Data targeting and referencing
# =============================================================================

sddt:targetsSensor a owl:ObjectProperty ;
    rdfs:label "targets sensor" ;
    rdfs:domain sddt:SensorData ;
    rdfs:range sddt:Point ;
    rdfs:comment "SensorData references the target sensing point." .

sddt:targetsTool a owl:ObjectProperty ;
    rdfs:label "targets tool" ;
    rdfs:domain sddt:ToolData ;
    rdfs:range sddt:Tool ;
    rdfs:comment "ToolData references the tool that produced or consumed it." .

sddt:referencesModel a owl:ObjectProperty ;
    rdfs:label "references model" ;
    rdfs:domain sddt:VirtualModelData ;
    rdfs:range sddt:VirtualModel ;
    rdfs:comment "VirtualModelData references the model that generated it." .

sddt:targetsModel a owl:ObjectProperty ;
    rdfs:label "targets model" ;
    rdfs:domain sddt:ModelParameter ;
    rdfs:range sddt:VirtualModel ;
    rdfs:comment "ModelParameter references the target virtual model." .

sddt:targetsComponent a owl:ObjectProperty ;
    rdfs:label "targets component" ;
    rdfs:domain sddt:ModelParameter ;
    rdfs:range sddt:PhysicalEntity ;
    rdfs:comment "ModelParameter references the target physical component." .

sddt:targetsSystem a owl:ObjectProperty ;
    rdfs:label "targets system" ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range sddt:PhysicalEntity ;
    rdfs:comment "VirtualModel targets a PhysicalEntity it is intended to represent." .

sddt:targetsControlLoop a owl:ObjectProperty ;
    rdfs:label "targets control loop" ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range sddt:ControlLoop ;
    rdfs:comment "VirtualModel targets a specific control loop." .

# =============================================================================
# OBJECT PROPERTIES — Control loop structure
# =============================================================================

sddt:hasControlVariable a owl:ObjectProperty ;
    rdfs:label "has control variable" ;
    rdfs:domain sddt:ControlLoop ;
    rdfs:range sddt:Point ;
    rdfs:comment "Control variable point used in the loop." .

sddt:hasSetpoint a owl:ObjectProperty ;
    rdfs:label "has setpoint" ;
    rdfs:domain sddt:ControlLoop ;
    rdfs:range sddt:Point ;
    rdfs:comment "Setpoint point used in the loop." .

sddt:hasSensor a owl:ObjectProperty ;
    rdfs:label "has sensor" ;
    rdfs:domain sddt:ControlLoop ;
    rdfs:range sddt:Point ;
    rdfs:comment "Sensor point used in the loop." .

sddt:hasActuator a owl:ObjectProperty ;
    rdfs:label "has actuator" ;
    rdfs:domain sddt:ControlLoop ;
    rdfs:range sddt:Point ;
    rdfs:comment "Actuator point used in the loop." .

# =============================================================================
# DATATYPE PROPERTIES — Generic / Entity-level
# =============================================================================

sddt:hasId a owl:DatatypeProperty ;
    rdfs:label "has id" ;
    rdfs:domain sddt:Entity ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier of an entity." .

sddt:hasConnectedServiceId a owl:DatatypeProperty ;
    rdfs:label "has connected service id" ;
    rdfs:domain sddt:Entity ;
    rdfs:range xsd:string ;
    rdfs:comment "String identifier of the service invocation event (sddt:hasServiceInvocationID on the executing Tool) that this entity participated in, supported, or produced." .

# =============================================================================
# DATATYPE PROPERTIES — DTData and subclasses
# =============================================================================

sddt:hasDTDataId a owl:DatatypeProperty ;
    rdfs:label "has DT data id" ;
    rdfs:subPropertyOf sddt:hasId ;
    rdfs:domain sddt:DTData ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for a DTData instance." .

sddt:hasValue a owl:DatatypeProperty ;
    rdfs:label "has value" ;
    rdfs:domain sddt:DTData ;
    rdfs:range xsd:string ;
    rdfs:comment "Stored value of a DTData instance." .

sddt:hasUnit a owl:DatatypeProperty ;
    rdfs:label "has unit" ;
    rdfs:domain sddt:DTData ;
    rdfs:range xsd:string ;
    rdfs:comment "Unit of measurement for a DTData value." .

sddt:hasTimestamp a owl:DatatypeProperty ;
    rdfs:label "has timestamp" ;
    rdfs:domain sddt:DTData ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "Timestamp of a DTData record." .

sddt:targetsVariable a owl:DatatypeProperty ;
    rdfs:label "targets variable" ;
    rdfs:domain sddt:DTData ;
    rdfs:range xsd:string ;
    rdfs:comment "Name of the target variable represented by the data." .

# =============================================================================
# DATATYPE PROPERTIES — PhysicalEntity and subclasses
# =============================================================================

sddt:hasPhysicalEntityId a owl:DatatypeProperty ;
    rdfs:label "has physical entity id" ;
    rdfs:subPropertyOf sddt:hasId ;
    rdfs:domain sddt:PhysicalEntity ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for a PhysicalEntity." .

sddt:hasPhysicalEntityName a owl:DatatypeProperty ;
    rdfs:label "has physical entity name" ;
    rdfs:domain sddt:PhysicalEntity ;
    rdfs:range xsd:string ;
    rdfs:comment "Human-readable name of a PhysicalEntity." .

sddt:hasPhysicalEntityType a owl:DatatypeProperty ;
    rdfs:label "has physical entity type" ;
    rdfs:domain sddt:PhysicalEntity ;
    rdfs:range xsd:string ;
    rdfs:comment "Type label for a PhysicalEntity." .

sddt:hasEquipmentType a owl:DatatypeProperty ;
    rdfs:label "has equipment type" ;
    rdfs:domain sddt:Equipment ;
    rdfs:range xsd:string ;
    rdfs:comment "Equipment type label such as AHU, VAV, or pump." .

sddt:hasManufacturer a owl:DatatypeProperty ;
    rdfs:label "has manufacturer" ;
    rdfs:domain sddt:Equipment ;
    rdfs:range xsd:string ;
    rdfs:comment "Manufacturer name of equipment." .

sddt:hasPointType a owl:DatatypeProperty ;
    rdfs:label "has point type" ;
    rdfs:domain sddt:Point ;
    rdfs:range xsd:string ;
    rdfs:comment "Point type label such as sensor, setpoint, or command." .

sddt:hasTargetLoop a owl:DatatypeProperty ;
    rdfs:label "has target loop" ;
    rdfs:domain sddt:ControlLoop ;
    rdfs:range xsd:string ;
    rdfs:comment "Target loop name or identifier." .

# =============================================================================
# DATATYPE PROPERTIES — VirtualModel and subclasses
# [FIX 1] Added hasVirtualModelId, hasModeler, hasModelingDate
# [FIX 2] Added hasModelDescription on PhysicalModel
# [FIX 3] Added hasSystemThreshold, hasSystemCondition, hasBoundaryCondition, hasDeviationValue on RuleModel
# [FIX 4] Added hasBehaviorTarget on BehaviorModel
# [FIX 5] Added hasCoordinateSystem on GeometricModel
# =============================================================================

sddt:hasVirtualModelId a owl:DatatypeProperty ;
    rdfs:label "has virtual model id" ;
    rdfs:subPropertyOf sddt:hasId ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for a VirtualModel instance." .

sddt:hasModeler a owl:DatatypeProperty ;
    rdfs:label "has modeler" ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Name or identifier of the person or team who created the virtual model." .

sddt:hasModelingDate a owl:DatatypeProperty ;
    rdfs:label "has modeling date" ;
    rdfs:domain sddt:VirtualModel ;
    rdfs:range xsd:date ;
    rdfs:comment "Date on which the virtual model was created or last revised." .

sddt:hasGoverningEquation a owl:DatatypeProperty ;
    rdfs:label "has governing equation" ;
    rdfs:domain sddt:PhysicalModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Governing equations defining the physical model." .

sddt:hasModelDescription a owl:DatatypeProperty ;
    rdfs:label "has model description" ;
    rdfs:domain sddt:PhysicalModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Textual description of the physical model scope and assumptions." .

sddt:hasSystemThreshold a owl:DatatypeProperty ;
    rdfs:label "has system threshold" ;
    rdfs:domain sddt:RuleModel ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Threshold value used by the rule model to evaluate system state deviation." .

sddt:hasSystemCondition a owl:DatatypeProperty ;
    rdfs:label "has system condition" ;
    rdfs:domain sddt:RuleModel ;
    rdfs:range xsd:string ;
    rdfs:comment "System condition outcome label such as normal or faulty, as determined by the rule model." .

sddt:hasBoundaryCondition a owl:DatatypeProperty ;
    rdfs:label "has boundary condition" ;
    rdfs:domain sddt:RuleModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Boundary condition under which the rule model is applicable." .

sddt:hasDeviationValue a owl:DatatypeProperty ;
    rdfs:label "has deviation value" ;
    rdfs:domain sddt:RuleModel ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Computed deviation value evaluated against the system threshold." .

sddt:hasBehaviorTarget a owl:DatatypeProperty ;
    rdfs:label "has behavior target" ;
    rdfs:domain sddt:BehaviorModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Target behaviour or control response that the behavior model represents." .

sddt:hasSpatialDimension a owl:DatatypeProperty ;
    rdfs:label "has spatial dimension" ;
    rdfs:domain sddt:GeometricModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Spatial dimension metadata for a geometric model." .

sddt:hasCoordinateSystem a owl:DatatypeProperty ;
    rdfs:label "has coordinate system" ;
    rdfs:domain sddt:GeometricModel ;
    rdfs:range xsd:string ;
    rdfs:comment "Coordinate system used by the geometric model such as Cartesian or WGS84." .

# =============================================================================
# DATATYPE PROPERTIES — Tool and subclasses
# =============================================================================

sddt:hasToolId a owl:DatatypeProperty ;
    rdfs:label "has tool id" ;
    rdfs:subPropertyOf sddt:hasId ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for a Tool." .

sddt:hasServiceInvocationID a owl:DatatypeProperty ;
    rdfs:label "has service invocation ID" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Records the specific service execution event generated after a service request to this Tool." .

sddt:hasServiceLatency a owl:DatatypeProperty ;
    rdfs:label "has service latency" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Time required to perform the requested service by the AI agent; a quality-of-service metric recorded on the executing Tool." .

sddt:hasServiceStatus a owl:DatatypeProperty ;
    rdfs:label "has service status" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Status of the service invocation event, such as completed, failed, or in progress." .

sddt:hasInputVariables a owl:DatatypeProperty ;
    rdfs:label "has input variables" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Input variables consumed by the tool during service execution." .

sddt:hasOutputVariables a owl:DatatypeProperty ;
    rdfs:label "has output variables" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Output variables generated by the tool during service execution." .

sddt:hasHyperparameters a owl:DatatypeProperty ;
    rdfs:label "has hyperparameters" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Hyperparameters used by the tool, stored as a JSON string." .

sddt:hasSystemMessage a owl:DatatypeProperty ;
    rdfs:label "has system message" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "System message describing the target system and operating context provided to the tool." .

sddt:hasTargetAlgorithm a owl:DatatypeProperty ;
    rdfs:label "has target algorithm" ;
    rdfs:domain sddt:Tool ;
    rdfs:range xsd:string ;
    rdfs:comment "Refers to the code or functions written for the algorithms used to operate the tool." .

sddt:hasFaultStatus a owl:DatatypeProperty ;
    rdfs:label "has fault status" ;
    rdfs:domain sddt:SimulationTool ;
    rdfs:range xsd:string ;
    rdfs:comment "Fault status output of the tool, such as normal or abnormal, applicable to diagnostic simulation tools such as FDD." .

sddt:hasFaultCategory a owl:DatatypeProperty ;
    rdfs:label "has fault category" ;
    rdfs:domain sddt:SimulationTool ;
    rdfs:range xsd:string ;
    rdfs:comment "Fault category label produced by a diagnostic simulation tool such as FDD." .

# =============================================================================
# DATATYPE PROPERTIES — AIAgent
# NOTE: hasAgentRole and hasTargetServiceType removed per manuscript Table 3.
# AIAgent class properties per Table 3: Agent ID, System messages, User prompts,
# Agent tuning parameters, Connected service ID, Service output, Service latency.
# =============================================================================

sddt:hasAgentId a owl:DatatypeProperty ;
    rdfs:label "has agent id" ;
    rdfs:subPropertyOf sddt:hasId ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range xsd:string ;
    rdfs:comment "Unique identifier for an AI agent." .

sddt:hasAgentSystemMessages a owl:DatatypeProperty ;
    rdfs:label "has agent system messages" ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range xsd:string ;
    rdfs:comment "System messages defining the agent policy or task scope." .

sddt:hasAgentUserPrompts a owl:DatatypeProperty ;
    rdfs:label "has agent user prompts" ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range xsd:string ;
    rdfs:comment "User prompts consumed by the agent during service execution." .

sddt:hasAgentTuningParameters a owl:DatatypeProperty ;
    rdfs:label "has agent tuning parameters" ;
    rdfs:domain sddt:AIAgent ;
    rdfs:range xsd:string ;
    rdfs:comment "Agent tuning parameters such as temperature and max tokens stored as a JSON string." .

# =============================================================================
# OWL RESTRICTIONS (SubClassOf axioms with someValuesFrom)
# =============================================================================

sddt:VirtualModel rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sddt:isVirtualModelOf ;
    owl:someValuesFrom sddt:PhysicalEntity
] .

sddt:Tool rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sddt:hasInput ;
    owl:someValuesFrom sddt:Entity
] .

sddt:AIAgent rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sddt:hasInput ;
    owl:someValuesFrom sddt:Entity
] .

sddt:SimulationTool rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sddt:hasInput ;
    owl:someValuesFrom sddt:DTData
] .
